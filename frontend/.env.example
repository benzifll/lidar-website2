# ─── Frontend Environment Variables ───────────────────────────────────────────
#
# Copy this file to .env.local for local development (backend on localhost).
# On Vercel, set these as Environment Variables in the dashboard.
#
# ──────────────────────────────────────────────────────────────────────────────

# HTTP/HTTPS base URL of your Python backend.
# Local dev (default — no need to set this in .env.local):
# NEXT_PUBLIC_API_URL=http://localhost:8765
#
# Vercel deployment — paste your ngrok / cloudflared tunnel URL here:
# NEXT_PUBLIC_API_URL=https://xxxx-xx-xx-xx-xx.ngrok-free.app

# WebSocket URL (derived automatically from NEXT_PUBLIC_API_URL if not set).
# Only override this if your WS endpoint lives at a different address.
# NEXT_PUBLIC_WS_URL=wss://xxxx-xx-xx-xx-xx.ngrok-free.app/ws
